# Backend API base URL (no trailing slash).
# Used for SSR fetches and /api/* rewrites in next.config.js.
API_URL=http://127.0.0.1:4000

# Canonical public site URL (sitemap, robots, Open Graph). Production default: https://nagarikpalika.com
# NEXT_PUBLIC_SITE_URL=https://nagarikpalika.com

# Google Search Console HTML tag verification (set in Vercel production env)
# GOOGLE_SITE_VERIFICATION=your-verification-code

# Optional: override glossary JSON directory (default: ./data)
# DATA_DIR=./data
