# =============================================================================
# Nagarik Palika frontend — copy to .env.local
# For Sajilo Kanun / legal RAG vars, also see ../.env.sajilokanun.example
# =============================================================================

# Express backend (auth, admin, demo requests). Used for SSR + /api/* rewrites.
API_URL=http://127.0.0.1:4000

# Canonical public URL (sitemap, robots, Open Graph). Production: https://nagarikpalika.com
# NEXT_PUBLIC_SITE_URL=https://nagarikpalika.com

# Google Search Console verification meta tag
# GOOGLE_SITE_VERIFICATION=

# Glossary JSON directory override (default: ./data)
# DATA_DIR=./data
