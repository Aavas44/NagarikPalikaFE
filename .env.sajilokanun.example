# =============================================================================
# Sajilo Kanun — legal RAG environment variables
# Copy these into frontend/.env.local (merge with API_URL from frontend/.env.example)
# Never commit .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# VECTOR DATABASE (required for chat / retrieval)
# -----------------------------------------------------------------------------
# Supabase project URL (public — safe in browser bundle if ever needed client-side)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
# Service role key — server-only; bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# LLM PROVIDER — chat answers + query embeddings
# -----------------------------------------------------------------------------
# openai | gemini
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4.1-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSION=768

# Required for advocate query normalization even when LLM_PROVIDER=openai
GEMINI_API_KEY=

# Use when LLM_PROVIDER=gemini instead of OpenAI for chat/embeddings:
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# QUERY NORMALIZATION (advocate mode — Gemini primary, OpenAI fallback)
# -----------------------------------------------------------------------------
# Translates Roman Nepali/English → search keywords + दफा hints before retrieval
# Text models: gemini-3.1-flash-lite | gemini-3.5-flash | gemini-3-flash-preview | gemini-2.5-flash-lite
# Not valid for text normalize: gemini-3.1-flash (404 — use -lite or gemini-3.5-flash)
QUERY_NORMALIZE_MODEL=gemini-3.1-flash-lite
# Used when primary Gemini fails (503, 429 quota/billing, etc.) — requires OPENAI_API_KEY
QUERY_NORMALIZE_FALLBACK_MODEL=gpt-5-nano
# QUERY NORMALIZE_THINKING_BUDGET=0
# Slim normalize (default): LLM fixes query + proposes दफा names; taxonomy reconciled locally (no ~20k-token prompt)
QUERY_NORMALIZE_SLIM=true
QUERY_NORMALIZE_RECONCILE_THRESHOLD=0.45
# Max unique दफा in advocate लागू प्रावधानहरू (early-stop at 1–2 when precise)
ADVOCATE_DAFA_MAX=3
# Full दफा taxonomy in Gemini system prompt (expensive; enables Gemini context cache):
# QUERY_NORMALIZE_SLIM=false
# Gemini Context Caching (most useful when QUERY_NORMALIZE_SLIM=false)
QUERY_NORMALIZE_USE_CONTEXT_CACHE=true
QUERY_NORMALIZE_CONTEXT_CACHE_TTL_SEC=86400
QUERY_NORMALIZE_CACHE_TTL_MS=86400000
# Skip Gemini attempts for 5 min after 429 billing errors (fast-path to OpenAI fallback)
# QUERY_NORMALIZE_GEMINI_DEPLETED_TTL_MS=300000
# QUERY_NORMALIZE_CACHE_MAX=500

# -----------------------------------------------------------------------------
# ADVOCATE ANALYSIS — LLM that writes the final advocate-mode answer
# -----------------------------------------------------------------------------
ADVOCATE_ANALYSIS_MODEL=gpt-4.1-nano

# -----------------------------------------------------------------------------
# RETRIEVAL — how chunks are fetched from Supabase
# -----------------------------------------------------------------------------
# auto = vector + PostgreSQL FTS with RRF fusion | vector | keyword
RETRIEVAL_MODE=auto
RETRIEVAL_TOP_K=8
SECTION_RETRIEVAL_TOP_K=24
RRF_K=60
HYBRID_CANDIDATE_MULTIPLIER=3

# Advocate mode — wider retrieval + more context in prompt
ADVOCATE_RETRIEVAL_TOP_K=24
ADVOCATE_CONTEXT_MAX=18
ADVOCATE_MIN_SECTION_HINTS_SKIP_EXPANSION=2
CHAPTER_EXPANSION_MAX_SECTIONS=6
PREFERRED_ACT_BOOST=0.12
# Unique दफा in विस्तृत स्रोत (includes related acts; answer tags stay at 3)
# ADVOCATE_UI_SOURCES_MAX=5
# ADVOCATE_VECTOR_CANDIDATES=48
# HIERARCHICAL_MIN_CHAPTER_SCORE=0.26
# HIERARCHICAL_CHAPTER_VECTOR_K=48
# HIERARCHICAL_CHAPTER_TOP_K=12

# -----------------------------------------------------------------------------
# INGESTION SCRIPTS ONLY (npm run sajilo:ingest, etc.) — not needed for dev server
# -----------------------------------------------------------------------------
# Direct Postgres URL for migrations (apply-fts-migration, setup-db). Runtime chat uses Supabase REST above.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Limit ingest to specific PDFs (pipe-separated if multiple: file1.pdf|file2.pdf)
# PILOT_MODE=true
# PILOT_PDFS=मुलुकी-अपराध-संहिता-ऐन-२०७४.pdf

# Chunk text cleanup during ingest: regex | gemini
# TEXT_CLEAN_PROVIDER=regex
# GEMINI_CLEAN_DELAY_MS=400
# EMBED_BATCH_SIZE=3
# EMBED_BATCH_DELAY_MS=2000

# PDF OCR during ingest (default: tesseract)
# OCR_PROVIDER=tesseract
# OCR_TESSERACT_LANGS=nep+eng
# OCR_PROVIDER=gemini
# GEMINI_OCR_MODEL=gemini-2.0-flash
# GEMINI_OCR_RPM=15

# -----------------------------------------------------------------------------
# DEV / BENCHMARK SCRIPTS ONLY
# -----------------------------------------------------------------------------
# HANDYLAW_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# RARELY NEEDED
# -----------------------------------------------------------------------------
# OPENAI_TIMEOUT_MS=120000
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.2
